---
interface Props {
    text: string;
    pathTo: string;
    typeOf?: string;
    isActive: string;
}

const { text, pathTo, typeOf = "boxed" } = Astro.props;
---

<a href={pathTo} }>
    <div
        class:list={[
            { boxed: typeOf === "boxed" },
            { simple: typeOf === "simple" },
        ]}
    >
        {text}
    </div>
</a>

<style>
    a {
        display: inline-block;
        padding: 8px 16px;
        text-decoration: none;
    }

    .boxed {
        color: #333;
        border-radius: 4px;
        background-color: #f0f0f0;
        transition: background-color 0.3s ease;
    }
    .boxed:hover {
        background-color: #e0e0e0;
    }
    .simple {
        color: #f0f0f0;
        border-bottom: 1px solid #f0f0f0;
    }
    .simple:active {
        color: #e0e0e0;
        border-bottom: 1px solid #e0e0e0;
    }
</style>
