---

---

<div class="gestationPeriod">
    <div class="container container-layout">
        <div class="container-header">
            <h2>Sheep Breeding Calculator</h2>
            <p class="subtitle">Calculate when the ram bred the ewe</p>
        </div>

        <div class="result-dateRange">
            <div class="dateValue">
                Early date <span id="shortDateResult">00-00-00</span>
            </div>
            <div class="dateValue targetDate">
                Target date<span id="standardDateResult">00-00-00</span>
            </div>
            <div class="dateValue">
                Late date<span id="longDateResult">00-00-00</span>
            </div>
        </div>

        <div class="container-inputs">
            <div class="input-group">
                <label for="birthDate">Lamb's Birth Date</label>
                <input type="date" id="birthDate" required />

                <label for="animalId">Animal ID</label>
                <input type="text" id="animalId" required />
            </div>
            <button id="storeDateAction">Store Date</button>
        </div>
    </div>
    <div class="container container-layout">
        <div class="container-header">
            <h2>Stored Dates</h2>

            <div class="birthdateItemsHeader">
                <div>Animal ID</div>
                <div>Date of Birth</div>
                <div>Estimated Bred date</div>
            </div>
            <ul id="birthDatesSaved" class="birthdateItems">
                <p class="noData">No Stored Dates</p>
            </ul>
        </div>
    </div>
</div>
<script src="./scripts/breedingCalculator.js"></script>
<style>
    .gestationPeriod {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 90%;
        gap: 18px;
    }
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    .noData {
        font-size: 0.7rem;
        color: #999;
        text-align: center;
    }
    .container {
        border-radius: 10px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        padding: 20px;
        max-width: 500px;
        width: 100%;
    }
    .container-layout {
        display: flex;
        flex-direction: column;
        gap: 24px;
        background: var(--accent-gray-color);
    }
    h1 {
        color: var(--white-color);
        text-align: center;
        margin-bottom: 10px;
        font-size: 38px;
    }
    .container-header {
        h2 {
            color: #333;
            text-align: center;
            margin-bottom: 10px;
            font-size: 28px;
        }
    }

    .subtitle {
        text-align: center;
        color: #667;
        font-size: 14px;
    }

    .input-group {
        margin-bottom: 25px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    label {
        display: block;
        color: #555;
        font-weight: 600;
        margin-bottom: 8px;
        font-size: 14px;
    }
    input {
        width: 100%;
        padding: 12px 15px;
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        font-size: 16px;
        transition: border-color 0.3s;
        font-family: inherit;
    }

    input:focus {
        outline: none;
        border-color: var(--primary-color);
    }

    button {
        width: 100%;
        padding: 15px;
        background: linear-gradient(
            135deg,
            var(--primary-color) 0%,
            var(--secondary-color) 100%
        );
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition:
            transform 0.2s,
            box-shadow 0.2s;
    }

    button:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
    }

    button:active {
        transform: translateY(0);
    }
    .dateResult {
        display: flex;
        flex-direction: column;
        font-size: 12px;
        align-items: center;

        justify-content: space-between;
        margin-bottom: 15px;
        font-size: 12px;
    }

    .result-dateRange {
        display: flex;
        justify-content: space-between;
        margin-bottom: 15px;
        font-size: 12px;
    }

    .result-title {
        color: #555;
        font-size: 14px;
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .dateValue {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        font-size: 15px;
        color: #000;
        font-weight: 900;
        span {
            color: #555;
            font-weight: 400;
            font-size: 0.9em;
        }
    }

    .birthdateItemsHeader {
        font-weight: 900;
        margin: 5px 0px;
    }
    .birthdateItems {
        display: flex;
        flex-direction: column;
        font-weight: 100;
        li {
            display: flex;
            justify-content: space-between;
            list-style: none;
            margin: 2px 0px;
            padding: 0px;
        }
    }
    .birthdateItemsHeader,
    .birthdateItems {
        display: flex;
        font-size: 12px;
        justify-content: space-between;
    }
    .targetDate {
    }
</style>
