---
import Html from "@layouts/Html.astro";
---

<Html>
    <div class="container container-layout">
        <div class="conatiner-header">
            <h1>Sheep Breeding Calculator</h1>
            <p class="subtitle">Calculate when the ram bred the ewe</p>
        </div>

        <div class="result-dateRange">
            <div class="dateValue">
                Short date <span id="shortDateResult">00-00-00</span>
            </div>
            <div class="dateValue">
                Standard date<span id="standardDateResult">00-00-00</span>
            </div>
            <div class="dateValue">
                Long date<span id="longDateResult">00-00-00</span>
            </div>
        </div>

        <div class="container-inputs">
            <div class="input-group">
                <label for="birthDate">Lamb's Birth Date</label>
                <input type="date" id="birthDate" value="2026-02-05" required />
            </div>
            <button id="calculateButton">Calculate Breeding Date</button>
        </div>

        <div class="info-box">
            <p>
                The standard sheep gestation period is 147 days (about 5
                months), but it can range from 145-150 days depending on breed
                and other factors.
            </p>
        </div>
    </div>

    <script src="./scripts/breedingCalculator.js"></script>
</Html>
<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    .container {
        background: var(--white-color);
        border-radius: 10px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        padding: 20px;
        max-width: 500px;
        width: 100%;
    }
    .container-layout {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    h1 {
        color: #333;
        text-align: center;
        margin-bottom: 10px;
        font-size: 28px;
    }

    .subtitle {
        text-align: center;
        color: #667;
        font-size: 14px;
    }

    .input-group {
        margin-bottom: 25px;
    }

    label {
        display: block;
        color: #555;
        font-weight: 600;
        margin-bottom: 8px;
        font-size: 14px;
    }

    input[type="date"] {
        width: 100%;
        padding: 12px 15px;
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        font-size: 16px;
        transition: border-color 0.3s;
        font-family: inherit;
    }

    input[type="date"]:focus {
        outline: none;
        border-color: var(--primary-color);
    }

    button {
        width: 100%;
        padding: 15px;
        background: linear-gradient(
            135deg,
            var(--primary-color) 0%,
            var(--secondary-color) 100%
        );
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition:
            transform 0.2s,
            box-shadow 0.2s;
    }

    button:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
    }

    button:active {
        transform: translateY(0);
    }
    .dateResult {
        display: flex;
        flex-direction: column;
        font-size: 12px;
        align-items: center;

        justify-content: space-between;
        margin-bottom: 15px;
        font-size: 12px;
    }

    .result-dateRange {
        display: flex;
        justify-content: space-between;
        margin-bottom: 15px;
        font-size: 12px;
    }

    @keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .result-title {
        color: #555;
        font-size: 14px;
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .dateValue {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        font-size: 15px;
        color: #000;
        font-weight: 900;
        span {
            color: #555;

            font-weight: 400;
            font-size: 0.9em;
        }
    }

    .info-box {
        background: #f0f4ff;
        border-left: 4px solid var(--primary-color);
        padding: 15px;
        border-radius: 8px;
        margin-top: 20px;
        font-size: 13px;
        color: #555;
    }
</style>
