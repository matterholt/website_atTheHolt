---
const { defaultValue, inputId, cardLabel } = Astro.props;
---

<div class:list={[`ingredient-card-${inputId}`, "cardLayout"]}>
    <h3 class="section-title">{cardLabel}</h3>
    {
        inputId === "target" ? null : (
            <input
                class="ingredient-name-input"
                id={inputId}
                type="text"
                value={defaultValue?.label}
                maxlength="24"
            />
        )
    }

    <div class="field-group">
        {
            inputId === "target" ? (
                <label for="target">Desired Crude Protein:</label>
            ) : (
                <label for={defaultValue?.inputValueId}>Crude Protein:</label>
            )
        }
        <div class="input-row">
            <input
                type="number"
                id={defaultValue?.inputValueId}
                min="0"
                max="100"
                step="0.1"
                value={defaultValue?.inputValue}
                placeholder="e.g. 8"
            />
            <span class="input-suffix">%</span>
        </div>
    </div>
</div>

<style>
    .field-group {
        display: flex;
        display: flex;
        flex-wrap: wrap;

        align-items: center;
        gap: 10px;
        grid-column: span 2;
    }

    label {
        display: block;
        font-size: 0.8em;
        font-weight: 700;
        color: var(--text);
        letter-spacing: 0.03em;
    }

    .input-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        input {
            border: none;
            border-bottom: 1.5px solid var(--primary-color);
            background: transparent;
            text-align: center;
            width: 43px;
        }
    }
    .ingredient-card {
        background: white;
        border: 1px solid rgba(160, 98, 42, 0.15);
        border-radius: 4px;
        padding: 1.2rem;
        position: relative;
    }

    .ingredient-card.a {
        border-left: 4px solid var(--green-field);
    }
    .ingredient-card.b {
        border-left: 4px solid var(--rust);
    }
    .input-suffix {
        font-family: "Source Code Pro", monospace;
        font-size: 0.85rem;
        color: var(--text-muted);
        white-space: nowrap;
        min-width: 2rem;
    }
    .ingredient-name-input {
        width: 100%;
        border: none;
        border-bottom: 1.5px solid var(--primary-color);
        background: transparent;
        font-family: "Playfair Display", serif;
        font-size: 1rem;
        font-weight: 700;
        color: var(--text);
        padding: 0.2rem 0;
        margin-bottom: 0.8rem;
        outline: none;
        transition: border-color 0.2s;
    }
    .section-title {
        font-family: "Source Code Pro", monospace;
        font-size: 0.65rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 0.8rem;
        border-bottom: 1px solid var(--parchment);
        padding-bottom: 0.4rem;
    }
    .cardLayout {
        display: grid;
        grid-template-columns: 1fr 3fr;
        grid-template-rows: 1fr 1fr;
    }
</style>
