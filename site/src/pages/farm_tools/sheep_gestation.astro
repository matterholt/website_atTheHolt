---
import Html from "@layouts/Html.astro";

import GestationPeriod from "@components/features/Gestations/GestationPeriod.astro";
import InformationBox from "@components/general/InformationBox.astro";
---

<Html>
    <div class="layout">
        <h1>Sheep Gestation Period</h1>
        <InformationBox>
            <p>
                The standard sheep gestation period is 147 days (about 5
                months), but it can range from 145-150 days depending on breed
                and other factors.
            </p>
        </InformationBox>

        <GestationPeriod />
    </div>
    <style>
        .layout {
            display: flex;
            flex-direction: column;
            align-items: center;
            max-width: 500px;
            gap: 18px;
        }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
    </style>
</Html>
