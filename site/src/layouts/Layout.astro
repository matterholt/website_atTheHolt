---
interface Props {
    currentPage: string;
}
import Footer from "@components/sections/Footer.astro";
import NavigationMain from "@components/sections/NavigationMain.astro";

const { currentPage } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <!-- <link rel="icon" type="image/svg+xml" href="/favicon.svg" /> -->
        <meta name="generator" content={Astro.generator} />
        <title>At the Holt</title>
    </head>

    <body class="center_layout">
        <NavigationMain currentPage={currentPage} />
        <slot name="header" />
        <slot name="main" />
        <Footer />
    </body>
</html>

<style is:global>
    html {
        --dark_green: #0f211a;
        --light_gray: #c9c9c9;
        --site_maxWidth: 1014px;

        margin: 0;
        color: var(--light_gray);
        background-color: var(--dark_green);
        font-size: 22px;
        font-family: "Gill Sans", sans-serif;
    }

    .center_layout {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 25px;
    }
    main {
        min-height: 90vh;
        display: flex;
        flex-direction: column;
        gap: 150px;
    }
    header,
    main,
    footer {
        max-width: var(--site_maxWidth);
    }
    .main_section_container {
        margin: 10px 5px;
        min-height: 550px;
    }
</style>
